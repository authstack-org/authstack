DATABASE_URL=postgres://postgres:password@localhost:5432/aegis
JWT_PRIVATE_KEY="<EC P-256 private key PEM>"
JWT_PUBLIC_KEY="<EC P-256 public key PEM>"
ACCESS_TOKEN_EXPIRY_SECS=900
REFRESH_TOKEN_EXPIRY_SECS=2592000
PORT=8080

# Bootstrap — first instance admin only (fresh database). Used by `make up` / entrypoint.
# AUTHSTACK_BOOTSTRAP_EMAIL=admin@example.com
# AUTHSTACK_BOOTSTRAP_PASSWORD=change-me
